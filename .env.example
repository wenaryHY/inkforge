# InkForge Docker 环境变量配置
# 复制为 .env 后修改：cp .env.example .env

# ===== 必须 =====
# JWT 签名密钥，生产环境务必修改！
INKFORGE_AUTH_SECRET=inkforge-change-me-in-production

# ===== 可选 =====
# 服务端口（默认 3000）
INKFORGE_PORT=3000

# 日志级别：debug / info / warn / error
RUST_LOG=info

# S3 数据库备份（不填则禁用 Litestream）
# LITESTREAM_S3_BUCKET=your-bucket
# AWS_REGION=ap-beijing
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
